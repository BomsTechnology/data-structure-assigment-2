import java.util.Scanner;
import util.BinarySearch;
import util.CSVWriter;

public class Main {

    public static void main(String[] args) {

        // Assume these arrays already exist from Task 1 
        Employee[] employeeArrayForSalary = ...; 
        Employee[] employeeArrayForName = ...;

        // Write sorted files
        CSVWriter.writeToCSV("sortedemployeeBySalary.csv", employeeArrayForSalary);
        CSVWriter.writeToCSV("sortedemployeeByName.csv", employeeArrayForName);

        // --------- Binary Search ----------
        Scanner scanner = new Scanner(System.in);

        System.out.print("Enter employee name to search: ");
        String searchName = scanner.nextLine();

        // Create a temporary Employee object only for searching
        Employee searchEmployee = new Employee(0, searchName, 0, 0, 0, 0, 0);

        int resultIndex = BinarySearch.search(employeeArrayForName, searchEmployee);

        if (resultIndex != -1) {
            System.out.println("Employee found at index: " + resultIndex);
            System.out.println(employeeArrayForName[resultIndex]);
        } else {
            System.out.println("Employee not found.");
        }

        scanner.close();
    }
}
